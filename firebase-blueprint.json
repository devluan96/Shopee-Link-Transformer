{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account details and approval status",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "isApproved": { "type": "boolean", "description": "Whether the admin has approved this user" },
        "isAdmin": { "type": "boolean", "description": "Admin status" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "isApproved"]
    },
    "Link": {
      "title": "Link Mapping",
      "description": "Stores the mapping between short codes and original Shopee URLs with custom metadata",
      "type": "object",
      "properties": {
        "originalUrl": { "type": "string", "description": "The sanitized Shopee product URL" },
        "shortCode": { "type": "string", "description": "Base62 or unique short identifier" },
        "userId": { "type": "string", "description": "Creator UID" },
        "customTitle": { "type": "string", "description": "Custom OG Title for social sharing" },
        "customDescription": { "type": "string", "description": "Custom OG Description" },
        "customImageUrl": { "type": "string", "description": "Custom OG Image URL" },
        "videoUrl": { "type": "string", "description": "URL of the uploaded video on Cloudinary" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["originalUrl", "shortCode", "userId", "createdAt"]
    },
    "Click": {
      "title": "Click Track",
      "description": "Stores tracking data for link redirects",
      "type": "object",
      "properties": {
        "linkId": { "type": "string", "description": "Reference to the Link document ID" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the click happened" },
        "ipHash": { "type": "string", "description": "SHA-256 hash of the user IP for anonymity" },
        "userAgent": { "type": "string", "description": "Browser user agent" },
        "referrer": { "type": "string", "description": "HTTP referrer" },
        "utmSource": { "type": "string" },
        "utmMedium": { "type": "string" },
        "utmCampaign": { "type": "string" }
      },
      "required": ["linkId", "timestamp", "ipHash"]
    }
  },
  "firestore": {
    "users": {
       "schema": "User",
       "description": "User profiles and approval state"
    },
    "admins": {
       "schema": { "type": "object", "properties": { "uid": { "type": "string" } } },
       "description": "Admin whitelist collection"
    },
    "links": {
      "schema": "Link",
      "description": "Collection of link mappings"
    },
    "clicks": {
      "schema": "Click",
      "description": "Collection of click tracking events"
    }
  }
}
