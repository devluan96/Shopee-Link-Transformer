# Cloudinary Config (Server-side upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Supabase authentication
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Firebase Admin service account. Use either a JSON string or a file path.
FIREBASE_SERVICE_ACCOUNT_KEY=
# Or if you prefer a file path to a downloaded JSON key:
# FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# App URL for redirects
APP_URL=https://hotsnew.click
